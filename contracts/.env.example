# Ethereum Sepolia Testnet RPC endpoint (Infura, Alchemy, or public RPC)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Private key of the wallet that will deploy and administer the
# CertificateRegistry contract. This wallet receives SUPERADMIN_ROLE.
# Fund it with Sepolia test ETH from https://sepoliafaucet.com
DEPLOYER_PRIVATE_KEY=

# Optional: for verifying the contract source on Etherscan
ETHERSCAN_API_KEY=
