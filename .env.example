# ============================================================
# NAUB Blockchain Certificate System — Environment Variables
# Copy this file to .env.local for local development
# Add these to Vercel Project Settings > Environment Variables
# ============================================================

# ------------------------------------------------------------------
# Blockchain — Ethereum Sepolia Testnet
# ------------------------------------------------------------------

# Deployed CertificateRegistry contract address (from: cd contracts && npm run deploy:sepolia)
# Leave empty to run in simulation mode (default for Vercel preview deployments)
CERTIFICATE_REGISTRY_ADDRESS=

# RPC endpoint for Sepolia (public default works, Infura/Alchemy recommended for production)
TESTNET_RPC_URL=https://rpc.sepolia.org

# Private key of the wallet that holds CERTIFICATE_ROLE on the deployed contract
# This wallet signs issueCertificate and revokeCertificate transactions
# Leave empty to run in simulation mode
TEST_WALLET_PRIVATE_KEY=

# ------------------------------------------------------------------
# Authentication — EIP-191 Wallet Signature + JWT
# ------------------------------------------------------------------

# Secret for signing JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated Ethereum wallet addresses that hold SUPERADMIN_ROLE
# These wallets can log in as Super Admin (Registrar / VC office)
SUPER_ADMIN_WALLETS=

# Comma-separated Ethereum wallet addresses that hold CERTIFICATE_ROLE
# These wallets can log in as Registry Admin (issuing staff)
REGISTRY_ADMIN_WALLETS=

# ------------------------------------------------------------------
# IPFS — Pinata (optional for production PDF storage)
# ------------------------------------------------------------------

# Pinata API key and secret for pinning certificate PDFs to IPFS
# Leave empty to use placeholder CIDs (fine for demo/evaluation)
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
